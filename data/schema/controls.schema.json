{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stella.local/stig-pilot-control-center/schemas/controls.schema.json",
  "title": "STIG Pilot Control Center Controls",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["control_id", "title", "product", "benchmark", "references"],
    "properties": {
      "control_id": { "type": "string" },
      "benchmark_id": { "type": "string" },
      "title": { "type": "string" },
      "product": { "type": "string" },
      "benchmark": { "type": "string" },
      "category": { "type": "string" },
      "tier": { "type": "string" },
      "wave": { "type": "string" },
      "owner_team": { "type": "string" },
      "owner_person": { "type": "string" },
      "implementation_method": { "type": "string" },
      "validation_method": { "type": "string" },
      "rollback_note": { "type": "string" },
      "references": {
        "type": "object",
        "properties": {
          "disa_downloads_url": { "type": "string" },
          "stig_viewer_url": { "type": "string" },
          "nist_xccdf_url": { "type": "string" },
          "nist_scap_url": { "type": "string" }
        }
      }
    }
  }
}
